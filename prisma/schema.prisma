// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  SAVINGS
  CURRENT
}
enum TransactionStatus {
  PENDING
  FAILED
  SUCCESS
}
enum TransactionType {
  CREDIT
  DEBIT
}

model User {
  id Int @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firstName String?
  lastName String?
  phoneNumber String? @unique

  // stored as DateTime so age validation and date arithmetic work correctly
  dateOfBirth DateTime?
  address String?

  email String @unique
  password String

  bvn String?
  nin String?

  pin String?
  bvnVerified Boolean @default(false)
  ninVerified Boolean @default(false)

  isAdmin Boolean @default(false)

  // stores a hash of the refresh token so the raw token is never persisted.
  // null means the user is logged out
  refreshToken String?

  accounts Account[]

  @@map("users")
}

model Account {
  id Int @id @default(autoincrement())

  accountNumber String @unique

  // Decimal instead of Float to avoid floating-point rounding errors
  // that can silently corrupt financial calculations (e.g. 0.1 + 0.2 != 0.3)
  balance Decimal @default(0.0) @db.Decimal(18, 2)
  canDebit Boolean @default(true)
  canCredit Boolean @default(true)
  isActive Boolean @default(true)

  accountType AccountType
  dailyTransactionLimit Decimal? @db.Decimal(18, 2)
  lastTransactionDate DateTime?

  userId Int
  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[] @relation(name: "PrimaryAccount")
  counterpartyTransactions Transaction[] @relation(name: "CounterpartyAccount")

  @@map("accounts")
}

model Transaction {
  id Int @id @default(autoincrement())

  type TransactionType
  // Decimal for the same reason as Account.balance
  amount Decimal @db.Decimal(18, 2)
  reference String
  status TransactionStatus
  description String?

  // @map keeps the existing DB column name ("balancebefore") while exposing
  // the correctly-cased "balanceBefore" field in TypeScript — no migration needed
  balanceBefore Decimal @db.Decimal(18, 2) @map("balancebefore")
  balanceAfter  Decimal @db.Decimal(18, 2)

  accountId Int?
  account Account? @relation(fields: [accountId], references: [id], name: "PrimaryAccount")

  counterpartyAccountId Int?
  counterpartyAccount Account? @relation(fields: [counterpartyAccountId], references: [id], name: "CounterpartyAccount")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("transactions")
}
