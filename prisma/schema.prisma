// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionStatus {
  PENDING
  FAILED
  SUCCESS
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum TransactionSource {
  INTERNAL
  PAYSTACK
}

enum VirtualAccountStatus {
  PENDING
  ACTIVE
  FAILED
}

model User {
  id Int @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firstName String?
  lastName String?
  phoneNumber String? @unique

  // stored as DateTime so age validation and date arithmetic work correctly
  dateOfBirth DateTime?
  address String?

  email String @unique
  password String

  bvn String?
  nin String?

  pin String?
  bvnVerified Boolean @default(false)
  ninVerified Boolean @default(false)

  isAdmin Boolean @default(false)

  // stores a hash of the refresh token so the raw token is never persisted.
  // null means the user is logged out
  refreshToken String?

  wallet         Wallet?
  virtualAccount VirtualAccount?

  @@map("users")
}

model Wallet {
  id       Int     @id @default(autoincrement())
  balance  Decimal @default(0.0) @db.Decimal(18, 2)
  currency String  @default("NGN")
  isActive Boolean @default(true)

  dailyTransactionLimit Decimal? @db.Decimal(18, 2)

  // tracks the async state of the Paystack DVA assignment
  virtualAccountStatus VirtualAccountStatus @default(PENDING)

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])

  transactions             Transaction[] @relation("WalletTransactions")
  counterpartyTransactions Transaction[] @relation("CounterpartyWallet")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("wallets")
}

model VirtualAccount {
  id Int @id @default(autoincrement())

  paystackCustomerCode String
  accountNumber        String @unique
  accountName          String
  bankName             String
  bankCode             String

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("virtual_accounts")
}

model Transaction {
  id     Int               @id @default(autoincrement())
  type   TransactionType
  source TransactionSource @default(INTERNAL)

  // Decimal for the same reason as Wallet.balance
  amount Decimal @db.Decimal(18, 2)

  reference   String
  status      TransactionStatus
  description String?

  balanceBefore Decimal @db.Decimal(18, 2) @map("balance_before")
  balanceAfter  Decimal @db.Decimal(18, 2) @map("balance_after")

  // unique constraint prevents double-crediting on Paystack webhook retries
  paystackReference String? @unique @map("paystack_reference")

  walletId Int?
  wallet   Wallet? @relation(fields: [walletId], references: [id], name: "WalletTransactions")

  counterpartyWalletId Int?
  counterpartyWallet   Wallet? @relation(fields: [counterpartyWalletId], references: [id], name: "CounterpartyWallet")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("transactions")
}
