{
  "info": {
    "name": "Fintech API",
    "_postman_id": "fintech-api-collection-v2",
    "description": "Wallet system with Paystack virtual accounts.\n\n**Setup:**\n1. Register → the response body contains `accessToken` and `refreshToken` — the collection saves them automatically via test scripts.\n2. Complete profile: set personal info → set BVN → set transaction PIN (this creates your wallet and kicks off DVA assignment).\n3. Poll `GET /wallet` until `virtualAccountStatus` is `ACTIVE`, then use `GET /wallet/virtual-account` to see your account number.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string",
      "description": "Auto-populated after login or register"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string",
      "description": "Auto-populated after login or register"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) {",
                  "  pm.collectionVariables.set('access_token', res.accessToken);",
                  "  pm.collectionVariables.set('refresh_token', res.refreshToken);",
                  "  console.log('Tokens saved automatically');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) {",
                  "  pm.collectionVariables.set('access_token', res.accessToken);",
                  "  pm.collectionVariables.set('refresh_token', res.refreshToken);",
                  "  console.log('Tokens saved automatically');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) {",
                  "  pm.collectionVariables.set('access_token', res.accessToken);",
                  "  pm.collectionVariables.set('refresh_token', res.refreshToken);",
                  "  console.log('Tokens refreshed automatically');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["auth", "refresh"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Promote to Admin",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/promote-to-admin",
              "host": ["{{base_url}}"],
              "path": ["auth", "promote-to-admin"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"adminSecret\": \"your_admin_secret_here\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            },
            "body": {
              "mode": "none"
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/users/me",
              "host": ["{{base_url}}"],
              "path": ["users", "me"]
            }
          }
        },
        {
          "name": "Update Personal Info",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/users/personal-info",
              "host": ["{{base_url}}"],
              "path": ["users", "personal-info"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"phoneNumber\": \"+2348100000000\",\n  \"address\": \"123 Main Street, Lagos\",\n  \"dateOfBirth\": \"1995-06-15\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Set BVN",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/users/bvn",
              "host": ["{{base_url}}"],
              "path": ["users", "bvn"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bvn\": \"20012345678\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Set NIN",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/users/nin",
              "host": ["{{base_url}}"],
              "path": ["users", "nin"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nin\": \"12345678901\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Set Transaction PIN",
          "description": "Creates wallet + kicks off Paystack DVA assignment. Requires personal info and BVN to be set first. The wallet starts with virtualAccountStatus: PENDING — poll GET /wallet until it becomes ACTIVE.",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/users/transaction-pin",
              "host": ["{{base_url}}"],
              "path": ["users", "transaction-pin"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pin\": 1234,\n  \"confirmPin\": 1234\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Change Transaction PIN",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/users/transaction-pin",
              "host": ["{{base_url}}"],
              "path": ["users", "transaction-pin"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPin\": 1234,\n  \"newPin\": 5678,\n  \"confirmNewPin\": 5678\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "Wallet",
      "item": [
        {
          "name": "Get Wallet",
          "description": "Returns balance, currency, isActive, and virtualAccountStatus. Poll this until virtualAccountStatus is ACTIVE after setting your PIN.",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/wallet",
              "host": ["{{base_url}}"],
              "path": ["wallet"]
            }
          }
        },
        {
          "name": "Get Virtual Account",
          "description": "Returns your Paystack-assigned bank account number and bank name. Share this with anyone who wants to send you money. Only available once virtualAccountStatus is ACTIVE.",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/wallet/virtual-account",
              "host": ["{{base_url}}"],
              "path": ["wallet", "virtual-account"]
            }
          }
        },
        {
          "name": "Lookup Recipient",
          "description": "Verify a recipient's account before sending money. Pass their virtual account number (the Paystack-assigned bank account number).",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/wallet/lookup",
              "host": ["{{base_url}}"],
              "path": ["wallet", "lookup"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountNumber\": \"1234567890\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Deactivate Wallet",
          "description": "Soft-deactivates your wallet. No transfers in or out are possible while inactive.",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/wallet/deactivate",
              "host": ["{{base_url}}"],
              "path": ["wallet", "deactivate"]
            },
            "body": {
              "mode": "none"
            }
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Send Money",
          "description": "Transfer money to another user. Use their virtual account number (from GET /wallet/virtual-account or POST /wallet/lookup).",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/transaction/send-money",
              "host": ["{{base_url}}"],
              "path": ["transaction", "send-money"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountNumber\": \"1234567890\",\n  \"transactionPin\": 1234,\n  \"amount\": 500,\n  \"description\": \"Rent payment\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Get All Transactions",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/transaction/get-all-transactions?page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["transaction", "get-all-transactions"],
              "query": [
                { "key": "page", "value": "1", "description": "Page number (default: 1)" },
                { "key": "limit", "value": "10", "description": "Results per page (default: 10)" }
              ]
            }
          }
        },
        {
          "name": "Get Transaction",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/transaction/get-transaction?transactionId=1",
              "host": ["{{base_url}}"],
              "path": ["transaction", "get-transaction"],
              "query": [
                { "key": "transactionId", "value": "1", "description": "ID of the transaction to retrieve" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Webhooks",
      "item": [
        {
          "name": "Paystack Webhook (reference)",
          "description": "This endpoint is called by Paystack, not by you. It is listed here so you can manually replay webhook events during local development via the ngrok inspector at http://localhost:4040.\n\nPaystack signs every request with an HMAC-SHA512 signature in the x-paystack-signature header.",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-paystack-signature", "value": "sha512-signature-from-paystack" }
            ],
            "url": {
              "raw": "{{base_url}}/webhook/paystack",
              "host": ["{{base_url}}"],
              "path": ["webhook", "paystack"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event\": \"charge.success\",\n  \"data\": {\n    \"reference\": \"17732668945535zvp253mmmlbopl\",\n    \"amount\": 500000,\n    \"channel\": \"dedicated_nuban\",\n    \"currency\": \"NGN\",\n    \"status\": \"success\",\n    \"gateway_response\": \"Approved\",\n    \"metadata\": {\n      \"receiver_account_number\": \"1234567890\",\n      \"receiver_bank\": \"Test Bank\"\n    },\n    \"authorization\": {\n      \"receiver_bank_account_number\": \"1234567890\",\n      \"receiver_bank\": \"Test Bank\",\n      \"sender_bank_account_number\": \"XXXXXX4553\",\n      \"channel\": \"dedicated_nuban\"\n    },\n    \"customer\": {\n      \"id\": 346344592,\n      \"first_name\": \"John\",\n      \"last_name\": \"Doe\",\n      \"email\": \"john@example.com\",\n      \"customer_code\": \"CUS_xxxxxxxxx\",\n      \"phone\": \"+2348100000000\"\n    },\n    \"fees\": 5000\n  }\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    }
  ]
}
